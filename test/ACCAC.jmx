        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="Load UI Component By ID">
          <stringProp name="dataSource">pg_accac</stringProp>
          <stringProp name="queryType">Prepared Select Statement</stringProp>
          <stringProp name="query">SELECT
    c.&quot;ni_id&quot;,
    c.&quot;cv_type&quot;,
    c.&quot;ni_x&quot;,
    c.&quot;ni_y&quot;,
    c.&quot;ni_width&quot;,
    c.&quot;ni_height&quot;,
    c.&quot;cv_text&quot;,
    c.&quot;bl_visible&quot;
FROM sc_accac.&quot;tb_CMP&quot; c
WHERE c.&quot;ni_id&quot; = ?;</stringProp>
          <stringProp name="queryArguments">${CMP_ID}</stringProp>
          <stringProp name="queryArgumentsTypes">INTEGER</stringProp>
          <stringProp name="variableNames"></stringProp>
          <stringProp name="resultVariable"></stringProp>
          <stringProp name="queryTimeout"></stringProp>
          <stringProp name="resultSetMaxRows"></stringProp>
          <stringProp name="resultSetHandler">Store as String</stringProp>
        </JDBCSampler>
        <hashTree/>
        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="Load Antenna By ID">
          <stringProp name="dataSource">pg_accac</stringProp>
          <stringProp name="queryType">Prepared Select Statement</stringProp>
          <stringProp name="query">SELECT
    a.&quot;ni_id&quot;,
    m.&quot;cv_name&quot; AS model_name,
    c.&quot;cv_name&quot; AS city_name,
    s.&quot;cv_name&quot; AS status_name,
    s.&quot;cv_color&quot;,
    a.&quot;cv_note&quot;
FROM sc_accac.&quot;tb_ANT&quot; a
JOIN sc_accac.&quot;tb_MDL&quot; m
    ON m.&quot;ni_id&quot; = a.&quot;ni_MDL_id&quot;
JOIN sc_accac.&quot;tb_CITY&quot; c
    ON c.&quot;ni_id&quot; = a.&quot;ni_CITY_id&quot;
JOIN sc_accac.&quot;tb_STAT&quot; s
    ON s.&quot;ni_id&quot; = a.&quot;ni_STAT_id&quot;
WHERE a.&quot;ni_id&quot; = ?;</stringProp>
          <stringProp name="queryArguments">${ANT_ID}</stringProp>
          <stringProp name="queryArgumentsTypes">INTEGER</stringProp>
          <stringProp name="variableNames"></stringProp>
          <stringProp name="resultVariable"></stringProp>
          <stringProp name="queryTimeout"></stringProp>
          <stringProp name="resultSetMaxRows"></stringProp>
          <stringProp name="resultSetHandler">Store as String</stringProp>
        </JDBCSampler>
