        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="01 DB Connection OK">
          <stringProp name="dataSource">pg_accac</stringProp>
          <stringProp name="query">SELECT &apos;OK&apos; AS result, current_database() AS db_name;</stringProp>
          <stringProp name="queryArguments"></stringProp>
          <stringProp name="queryArgumentsTypes"></stringProp>
          <stringProp name="queryTimeout"></stringProp>
          <stringProp name="queryType">Select Statement</stringProp>
          <stringProp name="resultSetHandler">Store as String</stringProp>
          <stringProp name="resultSetMaxRows"></stringProp>
          <stringProp name="resultVariable"></stringProp>
          <stringProp name="variableNames"></stringProp>
          <stringProp name="TestPlan.comments">Проверка подключения</stringProp>
        </JDBCSampler>
        <hashTree/>
        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="02 UI Components Exist">
          <stringProp name="dataSource">pg_accac</stringProp>
          <stringProp name="queryType">Select Statement</stringProp>
          <stringProp name="query">SELECT
	CASE
		WHEN COUNT(*) &gt; 0 THEN &apos;OK&apos;
		ELSE &apos;FAIL&apos;
	END AS result,
	COUNT(*) AS cmp_count
FROM sc_accac.&quot;tb_CMP&quot;
WHERE &quot;ni_LYT_id&quot; = 1;</stringProp>
          <stringProp name="queryArguments"></stringProp>
          <stringProp name="queryArgumentsTypes"></stringProp>
          <stringProp name="variableNames"></stringProp>
          <stringProp name="resultVariable"></stringProp>
          <stringProp name="queryTimeout"></stringProp>
          <stringProp name="resultSetMaxRows"></stringProp>
          <stringProp name="resultSetHandler">Store as String</stringProp>
          <stringProp name="TestPlan.comments">Проверсяем что из БД реально читаются компоненты интерфейса ACCAC</stringProp>
        </JDBCSampler>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Check UI Components OK">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="2524">OK</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message"></stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_data</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>
        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="03 UI Coordinates Valid">
          <stringProp name="dataSource">pg_accac</stringProp>
          <stringProp name="queryType">Select Statement</stringProp>
          <stringProp name="query">SELECT
    CASE
        WHEN COUNT(*) = 0 THEN &apos;OK&apos;
        ELSE &apos;FAIL&apos;
    END AS result,
    COUNT(*) AS invalid_count
FROM sc_accac.&quot;tb_CMP&quot;
WHERE
    (&quot;ni_x&quot; IS NOT NULL AND &quot;ni_x&quot; &lt; 0)
    OR (&quot;ni_y&quot; IS NOT NULL AND &quot;ni_y&quot; &lt; 0)
    OR (&quot;ni_width&quot; IS NOT NULL AND &quot;ni_width&quot; &lt;= 0)
    OR (&quot;ni_height&quot; IS NOT NULL AND &quot;ni_height&quot; &lt;= 0);</stringProp>
          <stringProp name="queryArguments"></stringProp>
          <stringProp name="queryArgumentsTypes"></stringProp>
          <stringProp name="variableNames"></stringProp>
          <stringProp name="resultVariable"></stringProp>
          <stringProp name="queryTimeout"></stringProp>
          <stringProp name="resultSetMaxRows"></stringProp>
          <stringProp name="resultSetHandler">Store as String</stringProp>
          <stringProp name="TestPlan.comments">Проверяем, что размеры и любыче числа валидны</stringProp>
        </JDBCSampler>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Check UI Coordinates OK">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="2524">OK</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message"></stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_data</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>
        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="04 Antenna Relations Valid">
          <stringProp name="dataSource">pg_accac</stringProp>
          <stringProp name="queryType">Select Statement</stringProp>
          <stringProp name="query">SELECT
    CASE
        WHEN COUNT(*) = 0 THEN &apos;OK&apos;
        ELSE &apos;FAIL&apos;
    END AS result,
    COUNT(*) AS invalid_count
FROM sc_accac.&quot;tb_ANT&quot; a
LEFT JOIN sc_accac.&quot;tb_MDL&quot; m
    ON m.&quot;ni_id&quot; = a.&quot;ni_MDL_id&quot;
LEFT JOIN sc_accac.&quot;tb_CITY&quot; c
    ON c.&quot;ni_id&quot; = a.&quot;ni_CITY_id&quot;
LEFT JOIN sc_accac.&quot;tb_STAT&quot; s
    ON s.&quot;ni_id&quot; = a.&quot;ni_STAT_id&quot;
WHERE
    m.&quot;ni_id&quot; IS NULL
    OR c.&quot;ni_id&quot; IS NULL
    OR s.&quot;ni_id&quot; IS NULL;</stringProp>
          <stringProp name="queryArguments"></stringProp>
          <stringProp name="queryArgumentsTypes"></stringProp>
          <stringProp name="variableNames"></stringProp>
          <stringProp name="resultVariable"></stringProp>
          <stringProp name="queryTimeout"></stringProp>
          <stringProp name="resultSetMaxRows"></stringProp>
          <stringProp name="resultSetHandler">Store as String</stringProp>
          <stringProp name="TestPlan.comments">Проверка ссылочной целостности антенн</stringProp>
        </JDBCSampler>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Check Antenna Relations OK">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="2524">OK</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message"></stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_data</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>
        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="05 UI Layout Load">
          <stringProp name="dataSource">pg_accac</stringProp>
          <stringProp name="queryType">Select Statement</stringProp>
          <stringProp name="query">SELECT
    c.&quot;ni_id&quot;,
    c.&quot;cv_type&quot;,
    c.&quot;ni_x&quot;,
    c.&quot;ni_y&quot;,
    c.&quot;ni_width&quot;,
    c.&quot;ni_height&quot;,
    c.&quot;cv_text&quot;,
    c.&quot;bl_visible&quot;,
    ctr.&quot;cv_name&quot; AS center_name,
    city.&quot;cv_name&quot; AS city_name,
    ant.&quot;ni_id&quot; AS antenna_id,
    mdl.&quot;cv_name&quot; AS model_name,
    stat.&quot;cv_name&quot; AS status_name
FROM sc_accac.&quot;tb_CMP&quot; c
LEFT JOIN sc_accac.&quot;tb_CTR&quot; ctr
    ON ctr.&quot;ni_id&quot; = c.&quot;ni_CTR_id&quot;
LEFT JOIN sc_accac.&quot;tb_CITY&quot; city
    ON city.&quot;ni_id&quot; = c.&quot;ni_CITY_id&quot;
LEFT JOIN sc_accac.&quot;tb_ANT&quot; ant
    ON ant.&quot;ni_id&quot; = c.&quot;ni_ANT_id&quot;
LEFT JOIN sc_accac.&quot;tb_MDL&quot; mdl
    ON mdl.&quot;ni_id&quot; = ant.&quot;ni_MDL_id&quot;
LEFT JOIN sc_accac.&quot;tb_STAT&quot; stat
    ON stat.&quot;ni_id&quot; = ant.&quot;ni_STAT_id&quot;
WHERE c.&quot;ni_LYT_id&quot; = 1
  AND c.&quot;bl_visible&quot; = TRUE
ORDER BY c.&quot;ni_id&quot;;</stringProp>
          <stringProp name="queryArguments"></stringProp>
          <stringProp name="queryArgumentsTypes"></stringProp>
          <stringProp name="variableNames"></stringProp>
          <stringProp name="resultVariable"></stringProp>
          <stringProp name="queryTimeout"></stringProp>
          <stringProp name="resultSetMaxRows"></stringProp>
          <stringProp name="resultSetHandler">Store as String</stringProp>
          <stringProp name="TestPlan.comments">Проверка загрузки макета интерфейса</stringProp>
        </JDBCSampler>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="05 UI Layout Load">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="104810015">ni_id</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message"></stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_data</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>
      </hashTree>
